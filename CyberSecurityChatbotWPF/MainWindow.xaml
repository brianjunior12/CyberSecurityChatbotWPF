<Window x:Class="CyberSecurityChatbotWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberSecurityChatbotWPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>

        <!-- HOME SCREEN -->
        <Grid x:Name="home_grid">

            <!-- Background Glow -->
            <Ellipse Width="500"
                     Height="500"
                     Fill="#0EA5E9"
                     Opacity="0.08"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Margin="-100,-100,0,0"/>

            <Ellipse Width="400"
                     Height="400"
                     Fill="#06B6D4"
                     Opacity="0.06"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom"
                     Margin="0,0,-100,-100"/>

            <Border Width="900"
                    Height="550"
                    CornerRadius="30"
                    Background="#111827"
                    BorderBrush="#06B6D4"
                    BorderThickness="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <StackPanel VerticalAlignment="Center">

                    <!-- ICON -->
                    <TextBlock Text="🛡"
                               FontSize="120"
                               HorizontalAlignment="Center"
                               Margin="0,30,0,10"/>

                    <!-- TITLE -->
                    <TextBlock Text="CYBERFORCE AI"
                               FontSize="48"
                               FontWeight="Bold"
                               Foreground="#06B6D4"
                               HorizontalAlignment="Center"/>

                    <!-- SUBTITLE -->
                    <TextBlock Text="Cybersecurity Awareness Assistant"
                               FontSize="22"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,10"/>

                    <!-- DESCRIPTION -->
                    <TextBlock Text="Stay safe online with intelligent cybersecurity guidance, phishing detection, password tips, malware awareness, and privacy protection."
                               FontSize="16"
                               Foreground="#CBD5E1"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Width="650"
                               Margin="0,25"/>

                    <!-- START BUTTON -->
                    <Button Content="START CHATBOT"
                            Width="280"
                            Height="65"
                            FontSize="22"
                            FontWeight="Bold"
                            Background="#06B6D4"
                            Foreground="Black"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="proceed"
                            Margin="0,20"/>

                </StackPanel>
            </Border>
        </Grid>

        <!-- USERNAME SCREEN -->
        <Grid x:Name="username_grid"
              Visibility="Hidden">

            <Border Width="550"
                    Height="380"
                    CornerRadius="25"
                    Background="#111827"
                    BorderBrush="#06B6D4"
                    BorderThickness="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <StackPanel Margin="40">

                    <TextBlock Text="WELCOME"
                               FontSize="36"
                               FontWeight="Bold"
                               Foreground="#06B6D4"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Please enter your name"
                               FontSize="18"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,15"/>

                    <!-- USERNAME BOX -->
                    <TextBox x:Name="usernames_input"
                             Height="55"
                             FontSize="20"
                             Margin="0,30"
                             Background="#1E293B"
                             Foreground="White"
                             BorderBrush="#06B6D4"
                             CaretBrush="White"
                             Padding="10"/>

                    <!-- SUBMIT BUTTON -->
                    <Button Content="CONTINUE"
                            Height="55"
                            FontSize="20"
                            FontWeight="Bold"
                            Background="#06B6D4"
                            Foreground="Black"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="submit_name"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- CHAT SCREEN -->
        <Grid x:Name="chat_grid"
              Visibility="Hidden">

            <Grid.RowDefinitions>
                <RowDefinition Height="85"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="95"/>
            </Grid.RowDefinitions>

            <!-- TOP BAR -->
            <Border Grid.Row="0"
                    Background="#111827"
                    BorderBrush="#06B6D4"
                    BorderThickness="0,0,0,2">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- BOT ICON -->
                    <TextBlock Text="🤖"
                               FontSize="42"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">

                        <TextBlock Text="CYBERFORCE SECURITY AI"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#06B6D4"/>

                        <TextBlock Text="Online and ready to protect you"
                                   Foreground="#CBD5E1"
                                   FontSize="13"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- CHAT AREA -->
            <Border Grid.Row="1"
                    Margin="15"
                    CornerRadius="20"
                    Background="#111827">

                <ListView x:Name="chats"
                          Background="Transparent"
                          BorderThickness="0"
                          Foreground="White"
                          FontSize="16"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Border>

            <!-- MESSAGE AREA -->
            <Grid Grid.Row="2"
                  Margin="15">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="170"/>
                </Grid.ColumnDefinitions>

                <!-- MESSAGE BOX -->
                <Border CornerRadius="15"
                        Background="#1E293B"
                        BorderBrush="#06B6D4"
                        BorderThickness="2">

                    <TextBox x:Name="question"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             FontSize="18"
                             Padding="20"
                             CaretBrush="White"
                             VerticalContentAlignment="Center"
                             KeyDown="UserInputBox_KeyDown"/>
                </Border>

                <!-- SEND BUTTON -->
                <Button Grid.Column="1"
                        Content="SEND"
                        Margin="15,0,0,0"
                        FontSize="20"
                        FontWeight="Bold"
                        Background="#06B6D4"
                        Foreground="Black"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="send"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
